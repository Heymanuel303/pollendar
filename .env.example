# ── Pollendar environment ───────────────────────────────────────────────────
# Copy to `.env` (backend reads this). Never commit the real .env.

# App / URLs
NODE_ENV=development
API_PORT=3000
# Public origin of the Vue frontend (used in magic-link + invite + result emails)
APP_URL=http://localhost:5173
# Comma-separated origins allowed by CORS (credentialed)
CORS_ORIGINS=http://localhost:5173

# Database (MySQL in docker-compose). Prisma reads DATABASE_URL.
MYSQL_DATABASE=pollendar
MYSQL_USER=pollendar
MYSQL_PASSWORD=pollendar
MYSQL_ROOT_PASSWORD=root
DATABASE_URL=mysql://pollendar:pollendar@localhost:3306/pollendar

# Auth — JWT (access in httpOnly cookie) + refresh sessions
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
# Magic-link single-use token lifetime
MAGIC_LINK_TTL=15m
# Cookie scope — leave EMPTY for a host-only cookie (works for localhost, LAN IPs,
# any host). RFC 6265 forbids IP literals in the Domain attribute, so never set this
# to an IP like 192.168.x.x — browsers reject it ("invalid domain"). Only set it to a
# real registered domain when you need the cookie shared across subdomains.
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Email — dev points at Mailpit (docker-compose). No auth needed for Mailpit.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="Pollendar <no-reply@pollendar.local>"

# Rate limiting (requests / window seconds) for magic-link + submissions
THROTTLE_TTL=60
THROTTLE_LIMIT=10
